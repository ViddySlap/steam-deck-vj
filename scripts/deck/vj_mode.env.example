# Steam Deck VJ Mode local overrides.
# Copy to ~/vj-mode/vj_mode.env and edit as needed.

# TouchOSC binary and default layout.
TOUCHOSC_BIN="$HOME/Applications/TouchOSC/TouchOSC"
TOUCHOSC_FILE="$HOME/Documents/TouchOSC/STEAMDECK V1.tosc"

# InputLeap startup inside Game Mode context.
INPUTLEAP_ENABLE=1
INPUTLEAP_MODE=server
INPUTLEAP_FLATPAK_APP="io.github.input_leap.input-leap"
INPUTLEAP_CONFIG="$HOME/.var/app/io.github.input_leap.input-leap/config/InputLeap/InputLeap.conf"
# Optional extra args, example:
# INPUTLEAP_EXTRA_ARGS='--name steamdeck'
INPUTLEAP_EXTRA_ARGS=""

# Optional sender auto-start.
SENDER_ENABLE=0
SENDER_CMD="$HOME/steam-deck-midi/scripts/deck/run_sender.sh"
